#!/usr/bin/env bash

set -x

if [[ "$(uname)" != "Darwin" ]]; then
	echo 'Not on macOS. Abort.'
	exit 0
fi
if [[ ! -d "$HOME/.cache" ]]; then
	mkdir ~/.cache
fi

# if type nix-shell >/dev/null && [[ -z $UPDATE_MACVIM_IN_NIX_SHELL ]]; then
# 	UPDATE_MACVIM_IN_NIX_SHELL=1 exec nix-shell \
# 		-p apple-sdk_26 xcbuild libiconv ncurses \
# 		--run "${BASH_SOURCE[0]} $@"
# fi

if [[ ! -d "$HOME/.cache/macvimbuild" ]]; then
	git clone https://github.com/macvim-dev/macvim ~/.cache/macvimbuild
	HASH=null
fi

if [[ "$1" == "--force" || "$1" == "-f" ]]; then
	# Forcely rebuild
	HASH=null
fi
cd ~/.cache/macvimbuild
HASH=${HASH:-$(git rev-parse HEAD)}
git pull
if [[ $HASH == $(git rev-parse HEAD) ]]; then
	exit 0
fi
export CONF_OPT_COMPBY="--with-compiledby=mityu"
export CONF_ARGS1='CC=clang'
# if [[ -n $NIX_HARDENING_ENABLE ]]; then
# 	# Same effect as `hardeningDisable = [ "format" ];` in mkDerivation.
# 	export NIX_HARDENING_ENABLE=${NIX_HARDENING_ENABLE//format/}
# 	export NIX_CFLAGS_COMPILE='-DOS_LOG_FORMAT_WARNINGS'
# fi

make -j4 || { make distclean && make -j4 ; }
if [[ $? -eq 0 ]]; then
	if [[ -d "/Applications/MacVim.app" ]]; then
		rm -r /Applications/MacVim.app
	fi
	cp -r ./src/MacVim/build/Release/MacVim.app /Applications/MacVim.app
fi
